# Preferred: kubectl create secret generic xuewen-secrets \
#              --from-literal=OPENAI_API_KEY=sk-...
# Alternative: cp secret.yaml.example secret.yaml, fill in the key, then
# kubectl apply -f deploy/k8s/secret.yaml (secret.yaml is gitignored).
# Without this Secret, Xuewen runs keyword-only (semantic search shows
# "unavailable" in the UI with the reason).
apiVersion: v1
kind: Secret
metadata:
  name: xuewen-secrets
type: Opaque
stringData:
  OPENAI_API_KEY: ""
