{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xuewen",
  "mainBinaryName": "xuewen-desktop",
  "version": "0.1.0",
  "identifier": "io.github.jiezhuzzz.xuewen",
  "build": {
    "frontendDist": "./dist-placeholder"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
    "externalBin": ["binaries/pdftotext", "binaries/node"],
    "resources": {
      "../agent-runner": "agent-runner",
      "binaries/libs": "libs"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
